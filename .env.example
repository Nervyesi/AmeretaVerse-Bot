# Discord Bot
DISCORD_TOKEN=your_bot_token_here

# Discord OAuth2 (from Discord Developer Portal → OAuth2)
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_secret

# Where the React frontend is running (for CORS + post-login redirect)
FRONTEND_URL=http://localhost:3000

# API server port (optional, default 8000)
API_PORT=8000
